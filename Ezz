        task.spawn(function()
            local rarities = { "Celestial", "Common", "Epic", "Godly", "Legendary", "Mythic", "Rare", "Secret" }

            local function normalize(text)
                if not text then return "" end
                return string.gsub(string.lower(text), "%s+", "")
            end

            local function getRequiredBrainrot()
                local rebirthRewardGui = LocalPlayer.PlayerGui:FindFirstChild("HUD", true)
                if rebirthRewardGui then
                    rebirthRewardGui = rebirthRewardGui:FindFirstChild("Rebirth", true)
                    if rebirthRewardGui then
                        rebirthRewardGui = rebirthRewardGui:FindFirstChild("InsiderFrame", true)
                        if rebirthRewardGui then
                            rebirthRewardGui = rebirthRewardGui:FindFirstChild("Insider", true)
                            if rebirthRewardGui then
                                rebirthRewardGui = rebirthRewardGui:FindFirstChild("Brainrots", true)
                                if rebirthRewardGui then
                                    rebirthRewardGui = rebirthRewardGui:FindFirstChild("RebirthReward", true)
                                    if rebirthRewardGui then
                                        for _, v in ipairs(rebirthRewardGui:GetDescendants()) do
                                            if v:IsA("TextLabel") and v.Text ~= "" then
                                                return v.Text
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
                return nil
            end

            local function findBrainrot(targetName)
                local target = normalize(targetName)
                local brainrotFolders = workspace.GameFolder:FindFirstChild("Brainrots", true)
                if not brainrotFolders then return nil end

                for _, rarity in ipairs(rarities) do
                    local folder = brainrotFolders:FindFirstChild(rarity)
                    if folder then
                        for _, brainrot in ipairs(folder:GetChildren()) do
                            local name = normalize(brainrot.Name)
                            if string.find(name, target) or string.find(target, name) then
                                return brainrot
                            end
                        end
                    end
                end
                return nil
            end

            while autoRebirthBrainrotActive do
                local char = LocalPlayer.Character
                local rootPart = char and char:FindFirstChild("HumanoidRootPart")
                local requiredName = getRequiredBrainrot()

                if rootPart and requiredName then
                    local brainrotToCollect = findBrainrot(requiredName)
                    if brainrotToCollect then
                        notify("Auto Rebirth BR", "تم العثور على: " .. brainrotToCollect.Name, 2)
                        local brRoot = brainrotToCollect:FindFirstChild("RootPart")
                        if brRoot then
                            pcall(function()
                                rootPart.CFrame = brRoot.CFrame * CFrame.new(0, 3, 0)
                                task.wait(0.25)
                                local prompt = brRoot:FindFirstChildOfClass("ProximityPrompt")
                                if prompt then
                                    fireproximityprompt(prompt)
                                    task.wait(0.3)
                                    
                                    rootPart.CFrame = homePosition
                                end
                            end)
                        end
                    end
                end
                task.wait(1.5) 
            end
        end)
    else
        notify("Auto Rebirth BR", "تم إيقاف جمع متطلبات الريبيرث", 3)
    end
end)


local function createAutoGetToggle(parent, sectionTitle, folderName, collectLimit)
    createSection(sectionTitle).Parent = parent
    
    createActionButton(parent, "TP to " .. folderName, function()
        local itemFolder = workspace.GameFolder.Brainrots:FindFirstChild(folderName)
        if itemFolder and #itemFolder:GetChildren() > 0 then
            local obj = itemFolder:GetChildren()[1]
            local root = obj:FindFirstChildWhichIsA("BasePart") or obj.PrimaryPart
            if root and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                LocalPlayer.Character.HumanoidRootPart.CFrame = root.CFrame * CFrame.new(0, 5, 0)
            end
        end
    end)

    local hunterActive = false
    local hunterCoroutine
    local connections = {}
    
    local function startHunter()
        if hunterCoroutine then task.cancel(hunterCoroutine) end
        for _, conn in ipairs(connections) do conn:Disconnect() end
        connections = {}

        hunterCoroutine = task.spawn(function()
            local itemFolder = workspace.GameFolder.Brainrots:FindFirstChild(folderName)
            if not itemFolder then return end

            local taskQueue = {}
            local collectedCount = 0

            local function addTask(item)
                if not table.find(taskQueue, item) then
                    table.insert(taskQueue, item)
                end
            end

            local childAddedConn = itemFolder.ChildAdded:Connect(addTask)
            table.insert(connections, childAddedConn)

            while hunterActive do
                collectedCount = 0
                notify("Auto Get", "بدء التجميع جديدة لـ " .. folderName, 3)

                while collectedCount < collectLimit and hunterActive do
                    for _, item in ipairs(itemFolder:GetChildren()) do
                        addTask(item)
                    end

                    if #taskQueue == 0 then
                        task.wait(1)
                    else
                        local item = table.remove(taskQueue, 1)

                        if item and item.Parent then
                            local rootPart = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                            if rootPart then
                                
                                rootPart.CFrame = homePosition
                                task.wait(0.1)

                                local targetPart = item:FindFirstChildWhichIsA("BasePart") or item.PrimaryPart
                                
                                if targetPart then
                                    local success = false
                                    for attempt = 1, 3 do
                                        if not item.Parent then success = true; break end
                                        rootPart.CFrame = targetPart.CFrame * CFrame.new(0, 3, 0)
                                        local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
                                        if prompt then pcall(function() fireproximityprompt(prompt) end) end
                                        task.wait(0.3)
                                    end

                                    if item.Parent == nil then success = true end
                                    if success then collectedCount = collectedCount + 1 end
                                    
                                    rootPart.CFrame = homePosition
                                end
                            end
                        end
                    end
                end
                
                if hunterActive then
                    notify("Auto Get", "اكتملت!، سيتم البدء من جديد بعد 1 ثانيه.", 4)
                    task.wait(1)
                end
            end
            
            childAddedConn:Disconnect()
        end)
    end

    createToggle(parent, "Auto Get " .. folderName, function(state, button)
        hunterActive = state
        if hunterActive then
            notify("Auto Get", "تم تفعيل الجمع لـ " .. folderName, 3)
            startHunter()
            
            local charAddedConn = LocalPlayer.CharacterAdded:Connect(function()
                task.wait(3)
                if hunterActive then
                    notify("Auto Get", "إعادة تشغيل الجمع بعد الموت", 3)
                    startHunter()
                end
            end)
            table.insert(connections, charAddedConn)
        else
            if hunterCoroutine then task.cancel(hunterCoroutine); hunterCoroutine = nil end
            for _, conn in ipairs(connections) do conn:Disconnect() end
            connections = {}
            notify("Auto Get", "تم إيقاف الجمع لـ " .. folderName, 3)
        end
    end)
end

